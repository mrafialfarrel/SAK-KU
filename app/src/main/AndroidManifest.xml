<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SAKKU">
        <activity
            android:name="uns.sakku.feature.transaction.presentation.TransactionActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.feature.saving.presentation.SavingActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.feature.report.presentation.ReportActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.feature.notification.presentation.NotificationActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.feature.pocket.presentation.NotificationActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.feature.export.presentation.ExportActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.feature.dashboard.presentation.DashboardActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.feature.auth.presentation.LoginActivity"
            android:exported="false" />
        <activity
            android:name="uns.sakku.UtamaActivity"
            android:exported="false"
            android:label="@string/title_activity_utama"
            android:theme="@style/Theme.SAKKU" />
        <activity
            android:name="uns.sakku.app.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.SAKKU">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name="uns.sakku.ProfileActivity" />
    </application>

</manifest>